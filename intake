<script>
  /* ============================================================
     WHERE SUBMISSIONS GO — set this ONE value.
     Paste your Google Apps Script Web App URL below.
     (Deploy the companion Apps Script as a Web App, "Anyone" access,
      then paste the /exec URL here.)
     Until it's set, the form falls back to opening an email to you.
  ============================================================ */
  const FORM_ENDPOINT = ""; // e.g. "https://script.google.com/macros/s/AKfy.../exec"

  const form = document.getElementById('intakeForm');
  const partA = document.getElementById('partA');
  const partB = document.getElementById('partB');
  const partFinal = document.getElementById('partFinal');
  const confirmBox = document.getElementById('confirm');
  const submitBtn = document.getElementById('submitBtn');
  const formError = document.getElementById('formError');

  // --- conditional branching ---
  function updateBranch() {
    const choice = form.querySelector('input[name="service"]:checked');
    const branch = choice ? choice.dataset.branch : null;
    partA.classList.toggle('show', branch === 'hipaa');
    partB.classList.toggle('show', branch === 'consult');
    partFinal.classList.toggle('show', !!branch);
  }
  form.querySelectorAll('input[name="service"]').forEach(r => r.addEventListener('change', updateBranch));

  // --- validation that respects hidden branches ---
  function activeBranch() {
    const choice = form.querySelector('input[name="service"]:checked');
    return choice ? choice.dataset.branch : null;
  }

  function validate() {
    const branch = activeBranch();
    // base required text/email/org inputs
    const baseRequired = ['fullName','title','email','org'];
    for (const id of baseRequired) {
      const el = document.getElementById(id);
      if (!el.value.trim()) return el;
    }
    if (!form.querySelector('input[name="size"]:checked')) return form.querySelector('input[name="size"]');
    if (!branch) return form.querySelector('input[name="service"]');

    if (branch === 'hipaa') {
      if (!document.getElementById('providers').value.trim()) return document.getElementById('providers');
      if (!form.querySelector('input[name="deadline"]:checked')) return form.querySelector('input[name="deadline"]');
    }
    if (branch === 'consult') {
      if (!form.querySelector('input[name="challenges"]:checked')) return form.querySelector('input[name="challenges"]');
      if (!document.getElementById('environment').value.trim()) return document.getElementById('environment');
    }
    if (!form.querySelector('input[name="timeline"]:checked')) return form.querySelector('input[name="timeline"]');

    // simple email sanity
    const email = document.getElementById('email');
    if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email.value.trim())) return email;

    return null;
  }

  function collect() {
    const data = {};
    const fd = new FormData(form);
    for (const [k, v] of fd.entries()) {
      if (k === 'challenges') { (data.challenges = data.challenges || []).push(v); }
      else { data[k] = v; }
    }
    // drop the branch we didn't use so the sheet stays clean
    const branch = activeBranch();
    if (branch !== 'hipaa') { delete data.providers; delete data.endpoints; delete data.deadline; }
    if (branch !== 'consult') { delete data.challenges; delete data.environment; }
    data.submittedAt = new Date().toISOString();
    return data;
  }

  function mailtoFallback(data) {
    const lines = Object.entries(data)
      .filter(([k]) => k !== '_gotcha')
      .map(([k, v]) => `${k}: ${Array.isArray(v) ? v.join(', ') : v}`)
      .join('%0D%0A');
    const subject = encodeURIComponent(`Engagement Intake — ${data.org || 'New inquiry'}`);
    window.location.href = `mailto:connect@chaundacdallas.com?subject=${subject}&body=${lines}`;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.remove('show');

    const bad = validate();
    if (bad) {
      formError.classList.add('show');
      bad.scrollIntoView({ behavior: 'smooth', block: 'center' });
      if (bad.focus) bad.focus();
      return;
    }

    const data = collect();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    // No endpoint set yet → graceful email fallback so nothing is lost.
    if (!FORM_ENDPOINT) {
      mailtoFallback(data);
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send & Scope It';
      return;
    }

    try {
      await fetch(FORM_ENDPOINT, {
        method: 'POST',
        mode: 'no-cors', // Apps Script write succeeds; response is opaque by design
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(data)
      });
      form.style.display = 'none';
      confirmBox.classList.add('show');
      confirmBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err) {
      // network failure → don't lose the lead, fall back to email
      formError.textContent = "Couldn't reach the server — opening an email to me instead so nothing gets lost.";
      formError.classList.add('show');
      setTimeout(() => mailtoFallback(data), 900);
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send & Scope It';
    }
  });

  // pre-select service from URL (?service=hipaa | ?service=consult)
  (function () {
    const svc = new URLSearchParams(window.location.search).get('service');
    const map = {
      hipaa:   'Emergency HIPAA Security Risk Assessment',
      consult: 'Professional Consultation / Advisory'
    };
    if (svc && map[svc]) {
      const target = Array.from(form.querySelectorAll('input[name="service"]'))
        .find(r => r.value === map[svc]);
      if (target) target.checked = true;
    }
  })();

  updateBranch();
</script>

