<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Scope Your Engagement — Chaunda C. Dallas</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --crimson: #1E5040;
    --crimson-dim: rgba(30,80,64,0.12);
    --crimson-glow: rgba(224,168,62,0.2);
    --pulse: #8B1E24;
    --black: #F3ECDD;
    --deep: #EAE0C8;
    --surface: #FFFFFF;
    --white: #3D4142;
    --white-dim: rgba(61,65,66,0.6);
    --white-faint: rgba(61,65,66,0.15);
    --gold: #E0A83E;
    --gold-dim: rgba(224,168,62,0.15);
    --border: rgba(61,65,66,0.14);
    --border-accent: rgba(30,80,64,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 15% 15%, rgba(30,80,64,0.07) 0%, transparent 55%),
      radial-gradient(ellipse 50% 70% at 85% 85%, rgba(224,168,62,0.04) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── UNIVERSAL NAV ── */
  .ccd-nav{position:sticky;top:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;padding:14px 28px;background:rgba(243,236,221,0.88);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(30,80,64,0.18);font-family:'DM Mono',ui-monospace,monospace;}
  .ccd-nav-brand{font-family:'Cormorant Garamond',Georgia,serif;font-size:18px;font-weight:600;letter-spacing:0.01em;color:#3D4142;text-decoration:none;white-space:nowrap;}
  .ccd-nav-dot{color:#1E5040;}
  .ccd-nav-links{display:flex;gap:24px;flex-wrap:wrap;}
  .ccd-nav-links a{font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(61,65,66,0.6);text-decoration:none;padding:4px 0;position:relative;transition:color .2s ease;}
  .ccd-nav-links a:hover{color:#3D4142;}
  .ccd-nav-links a.active{color:#1E5040;}
  .ccd-nav-links a.active::after{content:'';position:absolute;left:0;right:0;bottom:-3px;height:1px;background:#1E5040;}
  .nav-book{background:#E0A83E;color:#3D4142!important;padding:8px 14px;border-radius:2px;transition:background .2s ease;}
  .nav-book:hover{background:#C48F2E;color:#3D4142!important;}
  @media (max-width:600px){.ccd-nav{padding:12px 18px;gap:10px;}.ccd-nav-brand{font-size:16px;}.ccd-nav-links{gap:16px;width:100%;}.ccd-nav-links a{font-size:10px;letter-spacing:0.12em;}}

  .ecg-bar {
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, var(--pulse), transparent 60%);
    opacity: 0;
    animation: fadeIn 1s ease 0.1s forwards;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 28px 100px;
  }

  /* ── HEADER ── */
  .header {
    padding: 56px 0 40px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .header-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--crimson);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-eyebrow::after {
    content: '';
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: var(--crimson);
    opacity: 0.4;
  }

  .header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 5.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.12;
    color: var(--white);
    letter-spacing: -0.01em;
  }

  .header h1 .accent { color: var(--crimson); font-style: italic; }

  .header-sub {
    font-size: 13.5px;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.75;
    margin-top: 16px;
    max-width: 520px;
  }

  /* ── STATUS BANNER ── */
  .status-banner {
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1px solid rgba(30,80,64,0.2);
    border-left: 2px solid var(--crimson);
    padding: 14px 20px;
    margin-bottom: 48px;
    background: var(--crimson-glow);
    opacity: 0;
    animation: fadeUp 0.8s ease 0.35s forwards;
  }

  .pulse-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--pulse); flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  .status-text {
    font-family: 'DM Mono', monospace;
    font-size: 11px; color: var(--crimson); letter-spacing: 0.06em;
  }
  .status-text span { color: var(--white-dim); }

  /* ── FORM SHELL ── */
  form { opacity: 0; animation: fadeUp 0.8s ease 0.5s forwards; }

  fieldset { border: none; margin-bottom: 12px; }

  .section {
    border: 1px solid var(--border);
    background: var(--deep);
    padding: 30px 34px;
    margin-bottom: 2px;
  }
  .section:first-of-type { border-radius: 2px 2px 0 0; }

  .section-num {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--crimson);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .section-num::after { content:''; flex:1; height:1px; background: var(--border); }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 21px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 4px;
  }
  .section-hint {
    font-size: 12.5px;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* ── FIELDS ── */
  .field { margin-bottom: 20px; }
  .field:last-child { margin-bottom: 0; }

  .field label.q {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 9px;
  }
  .field label.q .req { color: var(--pulse); margin-left: 4px; }

  input[type="text"],
  input[type="email"],
  input[type="url"],
  textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1px;
    padding: 12px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--white);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--crimson);
    box-shadow: 0 0 0 3px rgba(30,80,64,0.10);
  }
  textarea { resize: vertical; min-height: 96px; line-height: 1.6; }
  input::placeholder, textarea::placeholder { color: rgba(61,65,66,0.4); }

  select {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1px;
    padding: 12px 40px 12px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--white);
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' stroke='%233D4142' stroke-width='1.5' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  select:focus {
    outline: none;
    border-color: var(--crimson);
    box-shadow: 0 0 0 3px rgba(30,80,64,0.10);
  }
  select:invalid { color: rgba(61,65,66,0.4); }

  /* ── CHOICE GROUPS ── */
  .choices { display: flex; flex-direction: column; gap: 8px; }

  .choice {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 1px;
    padding: 13px 16px;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .choice:hover { border-color: var(--border-accent); }
  .choice input { margin-top: 2px; accent-color: var(--crimson); flex-shrink: 0; width: 15px; height: 15px; cursor: pointer; }
  .choice input:checked ~ .choice-body .choice-label { color: var(--crimson); }
  .choice:has(input:checked) { border-color: var(--border-accent); background: rgba(30,80,64,0.04); }
  .choice-label { font-size: 13.5px; font-weight: 500; color: var(--white); line-height: 1.4; }
  .choice-sub { font-size: 12px; font-weight: 300; color: var(--white-dim); margin-top: 2px; line-height: 1.5; }

  /* ── CONDITIONAL BLOCKS ── */
  .conditional { display: none; }
  .conditional.show { display: block; animation: fadeUp 0.4s ease forwards; }

  .cond-tag {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(224,168,62,0.3);
    background: var(--gold-dim);
    padding: 4px 10px;
    border-radius: 1px;
    margin-bottom: 18px;
  }

  /* ── SUBMIT ── */
  .submit-row {
    border: 1px solid var(--border);
    border-top: none;
    background: var(--deep);
    border-radius: 0 0 2px 2px;
    padding: 26px 34px 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }
  .submit-note {
    font-size: 12px;
    font-weight: 300;
    color: var(--white-dim);
    line-height: 1.6;
    max-width: 340px;
  }
  .btn-submit {
    background: var(--gold);
    color: var(--white);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 14px 30px;
    border: none;
    border-radius: 1px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .btn-submit:hover { background: #C48F2E; }
  .btn-submit:disabled { opacity: 0.55; cursor: not-allowed; }

  /* honeypot */
  .hp { position: absolute; left: -9999px; opacity: 0; height: 0; overflow: hidden; }

  /* error line */
  .form-error {
    display: none;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--pulse);
    margin-top: 14px;
    letter-spacing: 0.02em;
  }
  .form-error.show { display: block; }

  /* ── CONFIRMATION ── */
  .confirm {
    display: none;
    border: 1px solid var(--border-accent);
    border-left: 2px solid var(--crimson);
    background: var(--deep);
    border-radius: 2px;
    padding: 44px 40px;
    text-align: left;
    opacity: 0;
  }
  .confirm.show { display: block; animation: fadeUp 0.6s ease forwards; }
  .confirm h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 14px;
  }
  .confirm p {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--white-dim);
    margin-bottom: 12px;
    max-width: 480px;
  }
  .confirm p a { color: var(--crimson); text-decoration: underline; }
  .confirm-sig {
    margin-top: 20px;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--gold);
  }

  /* ── FOOTER ── */
  .ccd-footer {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 24px; padding-top: 40px; margin-top: 48px;
    border-top: 1px solid var(--border);
    opacity: 0; animation: fadeUp 0.8s ease 0.7s forwards;
  }
  .ccd-footer-col { display: flex; flex-direction: column; gap: 9px; min-width: 140px; }
  .ccd-footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: var(--white); margin-bottom: 2px; }
  .ccd-footer-brand span { color: var(--crimson); }
  .ccd-footer-meta { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: var(--white-dim); text-transform: uppercase; opacity: 0.5; }
  .ccd-footer-heading { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 2px; }
  .ccd-footer-col a { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--white-dim); text-decoration: none; letter-spacing: 0.04em; opacity: 0.7; transition: color 0.2s ease; }
  .ccd-footer-col a:hover { color: var(--crimson); opacity: 1; }
  .ccd-footer-bottom {
    width: 100%; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 8px; padding-top: 18px; border-top: 1px solid var(--border);
    font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.06em; color: var(--white-dim); opacity: 0.55;
  }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.8); } }

  @media (prefers-reduced-motion: reduce) { * { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 600px) {
    .container { padding: 0 18px 70px; }
    .header { padding: 40px 0 32px; }
    .section { padding: 24px 20px; }
    .submit-row { padding: 22px 20px; flex-direction: column; align-items: stretch; }
    .btn-submit { width: 100%; }
    .confirm { padding: 32px 22px; }
    .ccd-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<!-- ===== CCD UNIVERSAL NAV BAR ===== -->
<nav class="ccd-nav">
  <a class="ccd-nav-brand" href="https://chaundacdallas.com">Chaunda C. Dallas<span class="ccd-nav-dot">.</span></a>
  <div class="ccd-nav-links">
    <a href="https://chaundacdallas.com">Home</a>
    <a href="https://chaundacdallas.com/#about">About</a>
    <a href="https://chaundacdallas.com/expertise">Expertise</a>
    <a href="https://chaundacdallas.com/services">Services</a>
    <a href="https://chaundacdallas.com/dfr-framework">DFR Framework</a>
    <a href="https://lab.chaundacdallas.com/" target="_blank" rel="noopener">DFR Lab</a>
    <a href="https://chaundacdallas.com/playbook">Playbook</a>
    <a href="https://chaundacdallas.com/documentary">Documentary</a>
    <a href="https://chaundacdallas.com/resources">Resources</a>
    <a href="https://chaundacdallas.com/contact">Contact</a>
    <a href="https://chaundacdallas.com/book" class="nav-book">Book a Session</a>
  </div>
</nav>
<!-- ===== END CCD NAV BAR ===== -->

<div class="ecg-bar"></div>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <div class="header-eyebrow">Engagement Intake</div>
    <h1>Let's scope <span class="accent">it.</span></h1>
    <p class="header-sub">A few direct questions so I walk into our first call already knowing your environment, your urgency, and what "done" looks like for you. No fluff — just what I need to give you a real answer.</p>
  </div>

  <!-- STATUS BANNER -->
  <div class="status-banner">
    <div class="pulse-dot"></div>
    <div class="status-text">
      TAKING ENGAGEMENTS &nbsp;·&nbsp; <span>HIPAA assessments available for immediate start · 5-day delivery</span>
    </div>
  </div>

  <!-- ============ FORM ============ -->
  <form id="intakeForm" novalidate>

    <!-- honeypot -->
    <div class="hp" aria-hidden="true">
      <label>Leave this field empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off"></label>
    </div>

    <!-- SECTION 1 -->
    <fieldset class="section">
      <div class="section-num">Section 01</div>
      <div class="section-title">Contact &amp; Organization</div>
      <div class="section-hint">Who I'll be working with, and the scale of what we're protecting.</div>

      <div class="field">
        <label class="q" for="fullName">Full Name <span class="req">*</span></label>
        <input type="text" id="fullName" name="fullName" required autocomplete="name">
      </div>
      <div class="field">
        <label class="q" for="title">Professional Title <span class="req">*</span></label>
        <input type="text" id="title" name="title" required autocomplete="organization-title" placeholder="e.g. Practice Administrator, CISO, Founder">
      </div>
      <div class="field">
        <label class="q" for="email">Work Email <span class="req">*</span></label>
        <input type="email" id="email" name="email" required autocomplete="email">
      </div>
      <div class="field">
        <label class="q" for="org">Organization / Practice Name <span class="req">*</span></label>
        <input type="text" id="org" name="org" required autocomplete="organization">
      </div>
      <div class="field">
        <label class="q" for="website">Website</label>
        <input type="url" id="website" name="website" placeholder="https://">
      </div>
      <div class="field">
        <label class="q">Organization Size <span class="req">*</span></label>
        <div class="choices">
          <label class="choice">
            <input type="radio" name="size" value="Small Practice / Startup (1–15)" required>
            <span class="choice-body"><span class="choice-label">Small Practice / Startup</span><span class="choice-sub">1–15 employees</span></span>
          </label>
          <label class="choice">
            <input type="radio" name="size" value="Mid-Sized Group / Facility (16–99)">
            <span class="choice-body"><span class="choice-label">Mid-Sized Group / Facility</span><span class="choice-sub">16–99 employees</span></span>
          </label>
          <label class="choice">
            <input type="radio" name="size" value="Enterprise Health System / Manufacturer (100+)">
            <span class="choice-body"><span class="choice-label">Enterprise Health System / Manufacturer</span><span class="choice-sub">100+ employees</span></span>
          </label>
        </div>
      </div>
    </fieldset>

    <!-- SECTION 2 -->
    <fieldset class="section">
      <div class="section-num">Section 02</div>
      <div class="section-title">What You're Scoping</div>
      <div class="section-hint">Pick one — the next section adapts to your choice.</div>

      <div class="field">
        <div class="choices">
          <label class="choice">
            <input type="radio" name="service" value="Emergency HIPAA Security Risk Assessment" required data-branch="hipaa">
            <span class="choice-body"><span class="choice-label">Emergency HIPAA Security Risk Assessment</span><span class="choice-sub">5-day turnaround · $2,500 flat fee</span></span>
          </label>
          <label class="choice">
            <input type="radio" name="service" value="Professional Consultation / Advisory" data-branch="consult">
            <span class="choice-body"><span class="choice-label">Professional Consultation / Advisory</span><span class="choice-sub">IoMT · Healthcare GRC · Clinical AI risk · Fractional retainer</span></span>
          </label>
        </div>
      </div>
    </fieldset>

    <!-- SECTION 3A — HIPAA (conditional) -->
    <fieldset class="section conditional" id="partA">
      <div class="section-num">Section 03 · A</div>
      <div class="section-title">HIPAA Assessment Scope</div>
      <span class="cond-tag">Shown because you chose the HIPAA assessment</span>

      <div class="field">
        <label class="q" for="providers">Clinical providers + administrative staff (estimate) <span class="req">*</span></label>
        <input type="text" id="providers" name="providers" data-cond="hipaa" placeholder="e.g. 6 providers, 12 staff">
      </div>
      <div class="field">
        <label class="q" for="endpoints">Network endpoints / connected medical devices (estimate)</label>
        <input type="text" id="endpoints" name="endpoints" placeholder="Rough count is fine — workstations, tablets, infusion pumps, monitors, etc.">
      </div>
      <div class="field">
        <label class="q">Is a deadline or audit driving this? <span class="req">*</span></label>
        <div class="choices">
          <label class="choice">
            <input type="radio" name="deadline" value="Hard deadline — under 30 days" data-cond="hipaa">
            <span class="choice-body"><span class="choice-label">Yes — hard deadline</span><span class="choice-sub">Under 30 days</span></span>
          </label>
          <label class="choice">
            <input type="radio" name="deadline" value="Standard window — 30–90 days" data-cond="hipaa">
            <span class="choice-body"><span class="choice-label">Yes — standard window</span><span class="choice-sub">30–90 days</span></span>
          </label>
          <label class="choice">
            <input type="radio" name="deadline" value="No deadline — proactive risk management" data-cond="hipaa">
            <span class="choice-body"><span class="choice-label">No active deadline</span><span class="choice-sub">Proactive risk management</span></span>
          </label>
        </div>
      </div>
    </fieldset>

    <!-- SECTION 3B — CONSULTATION (conditional) -->
    <fieldset class="section conditional" id="partB">
      <div class="section-num">Section 03 · B</div>
      <div class="section-title">Consultation Focus</div>
      <span class="cond-tag">Shown because you chose advisory / consultation</span>

      <div class="field">
        <label class="q">Primary challenge right now <span class="req">*</span> <span style="text-transform:none;letter-spacing:0;color:var(--white-dim);font-weight:400;">— select all that apply</span></label>
        <div class="choices">
          <label class="choice"><input type="checkbox" name="challenges" value="IoMT / Medical Device Vulnerability Management" data-cond="consult"><span class="choice-body"><span class="choice-label">IoMT / Medical Device Vulnerability Management</span></span></label>
          <label class="choice"><input type="checkbox" name="challenges" value="Clinical AI Risk & Governance Architecture"><span class="choice-body"><span class="choice-label">Clinical AI Risk &amp; Governance Architecture</span></span></label>
