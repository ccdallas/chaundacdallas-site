          <label class="choice">
            <input type="radio" name="timeline" value="Preliminary scoping (Q3/Q4)" data-cond="final">
            <span class="choice-body"><span class="choice-label">Just gathering info</span><span class="choice-sub">Preliminary scoping for later this year</span></span>
