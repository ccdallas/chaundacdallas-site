          <label class="choice"><input type="checkbox" name="challenges" value="Healthcare GRC Strategy & Framework Implementation"><span class="choice-body"><span class="choice-label">Healthcare GRC Strategy &amp; Framework Implementation</span></span></label>
          <label class="choice"><input type="checkbox" name="challenges" value="Strategic Advisory / Fractional Retainer Support"><span class="choice-body"><span class="choice-label">Strategic Advisory / Fractional Retainer Support</span></span></label>
