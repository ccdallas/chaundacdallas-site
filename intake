    <!-- SUBMIT -->
    <div class="submit-row" id="submitRow">
      <div class="submit-note">Your details go straight to me. I reply personally, usually within one business day.</div>
      <div style="text-align:right;">
        <button type="submit" class="btn-submit" id="submitBtn">Send &amp; Scope It</button>
        <div class="form-error" id="formError">Please complete the required fields above.</div>
